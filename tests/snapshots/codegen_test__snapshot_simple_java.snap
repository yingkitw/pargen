// Generated by pargen - do not edit manually

import java.util.*;

public class SimpleParser {
    public enum SimpleTokenKind {
        ID,
        WS,
        HELLO
        EOF
    }

    public static class SimpleToken {
        public final SimpleTokenKind kind;
        public final String text;
        public final int line;
        public final int col;

        public SimpleToken(SimpleTokenKind kind, String text, int line, int col) {
            this.kind = kind;
            this.text = text;
            this.line = line;
            this.col = col;
        }

        @Override
        public String toString() {
            return String.format("%s('%s') at %d:%d", kind, text, line, col);
        }
    }

    public static class SimpleLexer {
        private final String input;
        private int pos;
        private int line;
        private int col;

        public SimpleLexer(String input) {
            this.input = input;
            this.pos = 0;
            this.line = 1;
            this.col = 1;
        }

        public List<SimpleToken> tokenize() {
            List<SimpleToken> tokens = new ArrayList<>();
            while (pos < input.length()) {
                char c = input.charAt(pos);
                if (Character.isWhitespace(c)) { advance(); continue; }
                SimpleToken iD = tryMatchID();
                if (iD) {
                    tokens.add(iD); continue;
                }
                SimpleToken hELLO = tryMatchHELLO();
                if (hELLO) {
                    tokens.add(hELLO); continue;
                }
                throw new RuntimeException(String.format("Unexpected character '%%c' at line %%d col %%d", c, line, col));
            }

            tokens.add(new SimpleToken(SimpleTokenKind.EOF, "", line, col));
            return tokens;
        }

        private void advance() {
            if (pos < input.length()) {
                if (input.charAt(pos) == '\n') { line++; col = 1; }
                else { col++; }
                pos++;
            }
        }

        private char peek(int offset) {
            int p = pos + offset;
            return p < input.length() ? input.charAt(p) : '\0';
        }

        private SimpleToken tryMatchID() {
            int savedPos = pos;
            int savedLine = line;
            int savedCol = col;
            int start = pos;
            while (pos < input.length() && charInRange(input.charAt(pos))) { advance(); }
            if (pos == start) { return null; }
            String text = input.substring(start, pos);

            return new SimpleToken(SimpleTokenKind.ID, text, savedLine, savedCol);
        }

        private SimpleToken tryMatchWS() {
            int savedPos = pos;
            int savedLine = line;
            int savedCol = col;
            int start = pos;
            while (pos < input.length() && charInRange(input.charAt(pos))) { advance(); }
            if (pos == start) { return null; }
            String text = input.substring(start, pos);

            return null; // skip
        }

        private SimpleToken tryMatchHELLO() {
            int savedPos = pos;
            int savedLine = line;
            int savedCol = col;
            String target = "hello";
            for (int i = 0; i < target.length(); i++) {
                if (peek(i) != target.charAt(i)) { pos = savedPos; return null; }
            }
            String text = input.substring(savedPos, savedPos + target.length());
            for (int i = 0; i < target.length(); i++) { advance(); }
            return new SimpleToken(SimpleTokenKind.HELLO, text, savedLine, savedCol);
        }

    }

    public static class SimpleNode {
        public final String kind;
        public final List<SimpleNode> children = new ArrayList<>();
        public String text;
        public SimpleTokenKind tokenKind;

        public SimpleNode(String kind) {
            this.kind = kind;
        }

        public void addChild(SimpleNode child) {
            children.add(child);
        }

        @Override
        public String toString() {
            return toString(0);
        }

        public String toString(int indent) {
            StringBuilder sb = new StringBuilder();
            sb.append(" ".repeat(indent)).append(kind);
            if (text != null) sb.append(": '").append(text).append("'");
            sb.append('\n');
            for (SimpleNode child : children) sb.append(child.toString(indent + 2));
            return sb.toString();
        }
    }

    private final List<SimpleToken> tokens;
    private int pos;

    public SimpleParser(List<SimpleToken> tokens) {
        this.tokens = tokens;
        this.pos = 0;
    }

    public SimpleNode parse() {
        return parseStart();
    }

    private SimpleToken current() {
        return pos < tokens.size() ? tokens.get(pos) : tokens.get(tokens.size() - 1);
    }

    private SimpleToken matchToken(SimpleTokenKind kind) {
        if (current().kind == kind) { return tokens.get(pos++); }
        return null;
    }

    private SimpleToken expect(SimpleTokenKind kind) {
        SimpleToken tok = matchToken(kind);
        if (tok != null) return tok;
        SimpleToken cur = current();
        throw new RuntimeException(String.format("Unexpected token %%s ('%%s') at %%d:%%d", cur.kind, cur.text, cur.line, cur.col));
    }

    private SimpleNode parseStart() {
        SimpleNode node = new SimpleNode("start");
        { SimpleToken t = expect(SimpleTokenKind.HELLO); SimpleNode n = new SimpleNode("Token"); n.text = t.text; n.tokenKind = t.kind; node.addChild(n); }
        { SimpleToken t = expect(SimpleTokenKind.ID); SimpleNode n = new SimpleNode("Token"); n.text = t.text; n.tokenKind = t.kind; node.addChild(n); }
        return node;
    }


    public static void main(String[] args) {
        String input = "1 + 2 * 3";
        SimpleLexer lexer = new SimpleLexer(input);
        List<SimpleToken> tokens = lexer.tokenize();
        SimpleParser parser = new SimpleParser(tokens);
        SimpleNode tree = parser.parse();
        System.out.println(tree);
    }
}
