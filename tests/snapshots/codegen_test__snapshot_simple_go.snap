// Generated by pargen - do not edit manually

package simple

import (
	"fmt"
	"strings"
)

type SimpleTokenKind int

const (
	SimpleTokenEOF SimpleTokenKind = iota
	TokenID
	TokenWS
	TokenHELLO
)

func (k SimpleTokenKind) String() string {
	switch k {
		case SimpleTokenEOF: return "EOF"
		case TokenID: return "ID"
		case TokenWS: return "WS"
		case TokenHELLO: return "HELLO"
	}
	return fmt.Sprintf("Unknown(%d)", int(k))
}

type SimpleToken struct {
	Kind SimpleTokenKind
	Text string
	Line int
	Col  int
}

type SimpleLexer struct {
	input []rune
	pos   int
	line  int
	col   int
}

func NewSimpleLexer(input string) *SimpleLexer {
	return &SimpleLexer{input: []rune(input), pos: 0, line: 1, col: 1}
}

func (l *SimpleLexer) Tokenize() ([]SimpleToken, error) {
	var tokens []SimpleToken
	for l.pos < len(l.input) {
		c := l.input[l.pos]
		if c == ' ' || c == '\t' || c == '\n' || c == '\r' {
			l.advance()
			continue
		}
		if tok, ok := l.tryMatchID(); ok {
			tokens = append(tokens, tok)
			continue
		}
		if tok, ok := l.tryMatchHELLO(); ok {
			tokens = append(tokens, tok)
			continue
		}
		return nil, fmt.Errorf("unexpected character %c at line %d col %d", c, l.line, l.col)
	}

	tokens = append(tokens, SimpleToken{Kind: SimpleTokenEOF, Text: "", Line: l.line, Col: l.col})
	return tokens, nil
}

func (l *SimpleLexer) advance() {
	if l.pos < len(l.input) {
		if l.input[l.pos] == '\n' { l.line++; l.col = 1 } else { l.col++ }
		l.pos++
	}
}

func (l *SimpleLexer) peek() (rune, bool) {
	if l.pos < len(l.input) { return l.input[l.pos], true }
	return 0, false
}

func (l *SimpleLexer) tryMatchID() (SimpleToken, bool) {
	savedPos := l.pos
	savedLine := l.line
	savedCol := l.col
	start := l.pos
	for l.pos < len(l.input) {
		c := l.input[l.pos]
		if !charInRanges(c) { break }
		l.advance()
	}
	if l.pos == start { return SimpleToken{}, false }
	text := string(l.input[start:l.pos])

	return SimpleToken{Kind: TokenID, Text: text, Line: savedLine, Col: savedCol}, true
}

func (l *SimpleLexer) tryMatchWS() (SimpleToken, bool) {
	savedPos := l.pos
	savedLine := l.line
	savedCol := l.col
	start := l.pos
	for l.pos < len(l.input) {
		c := l.input[l.pos]
		if !charInRanges(c) { break }
		l.advance()
	}
	if l.pos == start { return SimpleToken{}, false }
	text := string(l.input[start:l.pos])

	return SimpleToken{}, true
}

func (l *SimpleLexer) tryMatchHELLO() (SimpleToken, bool) {
	savedPos := l.pos
	savedLine := l.line
	savedCol := l.col
	target := "hello"
	for i, c := range target {
		if l.pos + i >= len(l.input) || l.input[l.pos + i] != c { return SimpleToken{}, false }
	}
	text := string(l.input[l.pos:l.pos+len(target)])
	for _ = range target { l.advance() }
	return SimpleToken{Kind: TokenHELLO, Text: text, Line: savedLine, Col: savedCol}, true
}

type SimpleNode struct {
	Kind     string
	Children []*SimpleNode
	Token    *SimpleToken
}

func NewSimpleNode(kind string) *SimpleNode {
	return &SimpleNode{Kind: kind, Children: []*SimpleNode{}}
}

func NewTokenNode(tok SimpleToken) *SimpleNode {
	return &SimpleNode{Kind: "Token", Token: &tok, Children: []*SimpleNode{}}
}

func (n *SimpleNode) AddChild(child *SimpleNode) {
	n.Children = append(n.Children, child)
}

type SimpleParser struct {
	tokens []SimpleToken
	pos    int
}

func NewSimpleParser(tokens []SimpleToken) *SimpleParser {
	return &SimpleParser{tokens: tokens, pos: 0}
}

func (p *SimpleParser) Parse() (*SimpleNode, error) {
	return p.parseStart()
}

func (p *SimpleParser) current() SimpleToken {
	if p.pos < len(p.tokens) { return p.tokens[p.pos] }
	return p.tokens[len(p.tokens)-1]
}

func (p *SimpleParser) matchToken(kind SimpleTokenKind) (SimpleToken, bool) {
	if p.current().Kind == kind {
		tok := p.tokens[p.pos]
		p.pos++
		return tok, true
	}
	return SimpleToken{}, false
}

func (p *SimpleParser) expect(kind SimpleTokenKind) (SimpleToken, error) {
	if tok, ok := p.matchToken(kind); ok {
		return tok, nil
	}
	cur := p.current()
	return SimpleToken{}, fmt.Errorf("unexpected token %v ('%s') at line %d col %d", cur.Kind, cur.Text, cur.Line, cur.Col)
}

func (p *SimpleParser) parseStart() (*SimpleNode, error) {
	node := NewSimpleNode("start")
	if tok, err := p.expect(TokenHELLO); err != nil { return nil, err } else { node.AddChild(NewTokenNode(tok)) }
	if tok, err := p.expect(TokenID); err != nil { return nil, err } else { node.AddChild(NewTokenNode(tok)) }
	return node, nil
}

type SimpleLexError struct {
	Msg  string
	Line int
	Col  int
}

func (e SimpleLexError) Error() string {
	return fmt.Sprintf("%s at line %d col %d", e.Msg, e.Line, e.Col)
}

type SimpleParseError struct {
	Msg  string
	Line int
	Col  int
}

func (e SimpleParseError) Error() string {
	return fmt.Sprintf("%s at line %d col %d", e.Msg, e.Line, e.Col)
}

