#ifndef SIMPLE_PARSER_H
#define SIMPLE_PARSER_H

#include <stddef.h>
#include <stdlib.h>
#include <string.h>
#include <stdio.h>
#include <ctype.h>

typedef enum {
    Simple_Token_ID,
    Simple_Token_WS,
    Simple_Token_HELLO,
    Simple_Token_EOF,
} SimpleTokenKind;

typedef struct {
    SimpleTokenKind kind;
    char* text;
    int line;
    int col;
} SimpleToken;

typedef struct SimpleNode {
    char* kind;
    struct SimpleNode** children;
    int child_count;
    int child_capacity;
    char* text;
} SimpleNode;

typedef struct {
    const char* input;
    int pos;
    int line;
    int col;
} SimpleLexer;

SimpleLexer simple_lexer_new(const char* input);
SimpleToken* simple_lexer_tokenize(SimpleLexer* lexer, int* out_count);

typedef struct {
    SimpleToken* tokens;
    int count;
    int pos;
} SimpleParser;

SimpleParser simple_parser_new(SimpleToken* tokens, int count);
SimpleNode* simple_parser_parse(SimpleParser* parser);
SimpleNode* simple_node_new(const char* kind);
void simple_node_add_child(SimpleNode* parent, SimpleNode* child);
void simple_node_free(SimpleNode* node);

#endif /* SIMPLE_PARSER_H */

/* === Simple Lexer Implementation === */

SimpleLexer simple_lexer_new(const char* input) {
    SimpleLexer lexer = {input, 0, 1, 1};
    return lexer;
}

static void lexer_advance({prefix}Lexer* l) '{'
    if (l->pos < (int)strlen(l->input)) '{'
        if (l->input[l->pos] == '\n') { l->line++; l->col = 1; }
        else { l->col++; }
        l->pos++;
    }
}

SimpleToken* simple_lexer_tokenize(SimpleLexer* lexer, int* out_count) {
    int capacity = 64;
    SimpleToken* tokens = malloc(sizeof(SimpleToken) * capacity);
    int count = 0;
    int input_len = (int)strlen(lexer->input);

    while (lexer->pos < input_len) {
        char c = lexer->input[lexer->pos];
        if (isspace(c)) { lexer_advance(lexer); continue; }
        { SimpleToken tok = match_i_d(lexer);
        if (tok.text != NULL) {
            if (count >= capacity) { capacity *= 2; tokens = realloc(tokens, sizeof(tokens[0]) * capacity); }
            tokens[count++] = tok; continue;
        }}
        { SimpleToken tok = match_h_e_l_l_o(lexer);
        if (tok.text != NULL) {
            if (count >= capacity) { capacity *= 2; tokens = realloc(tokens, sizeof(tokens[0]) * capacity); }
            tokens[count++] = tok; continue;
        }}
        fprintf(stderr, "Unexpected character '%%c' at line %%d col %%d\n", c, lexer->line, lexer->col);
        free(tokens); return NULL;
    }

    if (count >= capacity) { capacity++; tokens = realloc(tokens, sizeof(tokens[0]) * capacity); }
    tokens[count].kind = Simple_Token_EOF;
    tokens[count].text = strdup("");
    tokens[count].line = lexer->line;
    tokens[count].col = lexer->col;
    count++;

    *out_count = count;
    return tokens;
}

static SimpleToken match_i_d(SimpleLexer* lexer) {
    int saved_pos = lexer->pos;
    int saved_line = lexer->line;
    int saved_col = lexer->col;
    int start = lexer->pos;
    int input_len = (int)strlen(lexer->input);
    while (lexer->pos < input_len && char_in_range(lexer->input[lexer->pos])) { lexer_advance(lexer); }
    if (lexer->pos == start) {
        SimpleToken none = {Simple_Token_EOF, NULL, 0, 0}; return none;
    }
    int len = lexer->pos - start;
    char* text = malloc(len + 1);
    strncpy(text, lexer->input + start, len);
    text[len] = '\0';

    return (SimpleToken){Simple_Token_ID, text, saved_line, saved_col};
}

static SimpleToken match_w_s(SimpleLexer* lexer) {
    int saved_pos = lexer->pos;
    int saved_line = lexer->line;
    int saved_col = lexer->col;
    int start = lexer->pos;
    int input_len = (int)strlen(lexer->input);
    while (lexer->pos < input_len && char_in_range(lexer->input[lexer->pos])) { lexer_advance(lexer); }
    if (lexer->pos == start) {
        SimpleToken none = {Simple_Token_EOF, NULL, 0, 0}; return none;
    }
    int len = lexer->pos - start;
    char* text = malloc(len + 1);
    strncpy(text, lexer->input + start, len);
    text[len] = '\0';

    return (SimpleToken){Simple_Token_EOF, text, saved_line, saved_col};
}

static SimpleToken match_h_e_l_l_o(SimpleLexer* lexer) {
    int saved_pos = lexer->pos;
    int saved_line = lexer->line;
    int saved_col = lexer->col;
    const char* target = "hello";
    int target_len = (int)strlen(target);
    int input_len = (int)strlen(lexer->input);
    for (int i = 0; i < target_len; i++) {
        if (lexer->pos + i >= input_len || lexer->input[lexer->pos + i] != target[i]) {
            SimpleToken none = {Simple_Token_EOF, NULL, 0, 0}; return none;
        }
    }
    char* text = malloc(target_len + 1);
    strncpy(text, lexer->input + saved_pos, target_len);
    text[target_len] = '\0';
    for (int i = 0; i < target_len; i++) { lexer_advance(lexer); }
    return (SimpleToken){Simple_Token_HELLO, text, saved_line, saved_col};
}

/* === Simple Parser Implementation === */

SimpleNode* simple_node_new(const char* kind) {
    SimpleNode* node = malloc(sizeof(SimpleNode));
    node->kind = strdup(kind);
    node->children = NULL;
    node->child_count = 0;
    node->child_capacity = 0;
    node->text = NULL;
    return node;
}

void simple_node_add_child(SimpleNode* parent, SimpleNode* child) {
    if (parent->child_count >= parent->child_capacity) {
        parent->child_capacity = parent->child_capacity == 0 ? 4 : parent->child_capacity * 2;
        parent->children = realloc(parent->children, sizeof(SimpleNode*) * parent->child_capacity);
    }
    parent->children[parent->child_count++] = child;
}

SimpleParser simple_parser_new(SimpleToken* tokens, int count) {
    SimpleParser parser = {tokens, count, 0};
    return parser;
}

static SimpleToken* parser_current(SimpleParser* p) {
    if (p->pos < p->count) return &p->tokens[p->pos];
    return &p->tokens[p->count - 1];
}

static SimpleToken* parser_match(SimpleParser* p, SimpleTokenKind kind) {
    if (parser_current(p)->kind == kind) { return &p->tokens[p->pos++]; }
    return NULL;
}

static SimpleToken* parser_expect(SimpleParser* p, SimpleTokenKind kind) {
    SimpleToken* tok = parser_match(p, kind);
    if (tok) return tok;
    SimpleToken* cur = parser_current(p);
    fprintf(stderr, "Unexpected token at line %%d col %%d\n", cur->line, cur->col);
    exit(1);
    return NULL;
}

SimpleNode* simple_parser_parse(SimpleParser* parser) {
    return parse_start(parser);
}

static SimpleNode* parse_start(SimpleParser* p) {
    SimpleNode* node = simple_node_new("start");
    { SimpleToken* t = parser_expect(p, Simple_Token_HELLO);
      SimpleNode* tn = simple_node_new("Token"); tn->text = strdup(t->text); simple_node_add_child(node, tn); }
    { SimpleToken* t = parser_expect(p, Simple_Token_ID);
      SimpleNode* tn = simple_node_new("Token"); tn->text = strdup(t->text); simple_node_add_child(node, tn); }
    return node;
}

void simple_node_free(SimpleNode* node) {
    if (!node) return;
    for (int i = 0; i < node->child_count; i++) {
        simple_node_free(node->children[i]);
    }
    free(node->children);
    free(node->kind);
    if (node->text) free(node->text);
    free(node);
}

static int char_in_range(char c) { return 0; /* implement based on grammar */ }
