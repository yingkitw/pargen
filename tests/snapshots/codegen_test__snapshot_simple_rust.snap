    WS,
    HELLO,
    Eof,
}

impl fmt::Display for SimpleTokenKind {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            SimpleTokenKind::ID => write!(f, "ID"),
            SimpleTokenKind::WS => write!(f, "WS"),
            SimpleTokenKind::HELLO => write!(f, "HELLO"),
            SimpleTokenKind::Eof => write!(f, "EOF"),
