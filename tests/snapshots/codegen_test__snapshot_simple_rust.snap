#[derive(Debug, Clone)]
pub enum SimpleNode {
    start { children: Vec<SimpleNode> },
    Token { kind: SimpleTokenKind, text: String },
}

pub struct SimpleParser {
    tokens: Vec<SimpleToken>,
    pos: usize,
}

impl SimpleParser {
    pub fn new(tokens: Vec<SimpleToken>) -> Self {
        Self { tokens, pos: 0 }
    }

    pub fn parse(&mut self) -> Result<SimpleNode, SimpleParseError> {
        self.parse_start()
    }

    fn current(&self) -> &SimpleToken {
        self.tokens.get(self.pos).unwrap_or_else(|| self.tokens.last().unwrap())
    }

    fn match_token(&mut self, kind: SimpleTokenKind) -> Option<&SimpleToken> {
        if self.current().kind == kind {
            let tok = &self.tokens[self.pos];
            self.pos += 1;
            Some(tok)
        } else {
            None
        }
    }

    fn expect(&mut self, kind: SimpleTokenKind) -> Result<&SimpleToken, SimpleParseError> {
        if let Some(_tok) = self.match_token(kind) {
            Ok(&self.tokens[self.pos - 1])
        } else {
            let cur = self.current();
            Err(SimpleParseError::UnexpectedToken(cur.kind, cur.text.clone(), cur.line, cur.col))
        }
    }

    fn parse_start(&mut self) -> Result<SimpleNode, SimpleParseError> {
        let mut children: Vec<SimpleNode> = Vec::new();
        children.push(SimpleNode::Token { kind: SimpleTokenKind::HELLO, text: self.expect(SimpleTokenKind::HELLO)?.text.clone() });
        children.push(SimpleNode::Token { kind: SimpleTokenKind::ID, text: self.expect(SimpleTokenKind::ID)?.text.clone() });
        Ok(SimpleNode::start { children })
    }

}

#[derive(Debug)]
pub enum SimpleLexError {
    UnexpectedChar(char, usize, usize),
    UnterminatedString(usize),
}

impl fmt::Display for SimpleLexError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            SimpleLexError::UnexpectedChar(c, line, col) => write!(f, "Unexpected character '{}' at line {} col {}", c, line, col),
            SimpleLexError::UnterminatedString(line) => write!(f, "Unterminated string at line {}", line),
        }
    }
}

impl std::error::Error for SimpleLexError {}

#[derive(Debug)]
pub enum SimpleParseError {
    UnexpectedToken(SimpleTokenKind, String, usize, usize),
    NoRules,
}

impl fmt::Display for SimpleParseError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            SimpleParseError::UnexpectedToken(kind, text, line, col) => write!(f, "Unexpected token '{}' ('{}') at line {} col {}", kind, text, line, col),
            SimpleParseError::NoRules => write!(f, "No parser rules defined"),
        }
    }
}

impl std::error::Error for SimpleParseError {}
