pub struct SimpleLexer {
    input: Vec<char>,
    pos: usize,
    line: usize,
    col: usize,
}

impl SimpleLexer {
    pub fn new(input: &str) -> Self {
        Self { input: input.chars().collect(), pos: 0, line: 1, col: 1 }
    }

    pub fn tokenize(&mut self) -> Result<Vec<SimpleToken>, SimpleLexError> {
        let mut tokens = Vec::new();
        while self.pos < self.input.len() {
            let c = self.input[self.pos];
            if c.is_whitespace() {
                self.advance();
                continue;
            }
            if let Some(token) = self.try_match_i_d() {
                tokens.push(token);
                continue;
            }
            if let Some(token) = self.try_match_h_e_l_l_o() {
                tokens.push(token);
                continue;
            }
            return Err(SimpleLexError::UnexpectedChar(c, self.line, self.col));
        }

        tokens.push(SimpleToken { kind: SimpleTokenKind::Eof, text: String::new(), line: self.line, col: self.col });
        Ok(tokens)
    }

    fn advance(&mut self) {
        if self.pos < self.input.len() {
            if self.input[self.pos] == '\n' { self.line += 1; self.col = 1; }
            else { self.col += 1; }
            self.pos += 1;
        }
    }

    fn peek(&self) -> Option<char> {
        self.input.get(self.pos).copied()
    }

    fn peek_at(&self, offset: usize) -> Option<char> {
        self.input.get(self.pos + offset).copied()
    }

    fn make_token(&self, kind: SimpleTokenKind, text: String, start_line: usize, start_col: usize) -> SimpleToken {
        SimpleToken { kind, text, line: start_line, col: start_col }
    }

    fn try_match_i_d(&mut self) -> Option<SimpleToken> {
        let saved_pos = self.pos;
        let saved_line = self.line;
        let saved_col = self.col;

        // match one or more of charset: [a-z]
        let mut len = 0;
        while let Some(c) = self.peek_at(len) {
            if Self::char_in_ranges(c, &RANGES) { len += 1; } else { break; }
        }
        if len == 0 { self.pos = saved_pos; return None; }
        for _ in 0..len { self.advance(); }
        let text = self.input[saved_pos..self.pos].iter().collect::<String>();

        Some(self.make_token(SimpleTokenKind::ID, text, saved_line, saved_col))
    }

    fn try_match_w_s(&mut self) -> Option<SimpleToken> {
        let saved_pos = self.pos;
        let saved_line = self.line;
        let saved_col = self.col;

        // match one or more of charset: [\t\n]
        let mut len = 0;
        while let Some(c) = self.peek_at(len) {
            if Self::char_in_ranges(c, &RANGES) { len += 1; } else { break; }
        }
        if len == 0 { self.pos = saved_pos; return None; }
        for _ in 0..len { self.advance(); }
        let text = self.input[saved_pos..self.pos].iter().collect::<String>();

        None
    }

    fn try_match_h_e_l_l_o(&mut self) -> Option<SimpleToken> {
        let saved_pos = self.pos;
        let saved_line = self.line;
        let saved_col = self.col;
        let target = "hello";
        for (i, c) in target.chars().enumerate() {
            if self.peek_at(i) != Some(c) { return None; }
        }
        for _ in target.chars() { self.advance(); }
        let text = self.input[saved_pos..self.pos].iter().collect::<String>();
        Some(self.make_token(SimpleTokenKind::HELLO, text, saved_line, saved_col))
    }

