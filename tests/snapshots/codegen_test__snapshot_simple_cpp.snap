// Generated by pargen - do not edit manually

#ifndef SIMPLE_PARSER_HPP
#define SIMPLE_PARSER_HPP

#include <string>
#include <vector>
#include <memory>
#include <stdexcept>
#include <optional>
#include <sstream>

enum class SimpleTokenKind {
    ID,
    WS,
    HELLO,
    Eof,
};

struct SimpleToken {
    SimpleTokenKind kind;
    std::string text;
    int line = 0;
    int col = 0;
};

class SimpleLexer {
    public:
        explicit SimpleLexer(const std::string& input) : input_(input), pos_(0), line_(1), col_(1) {}

        std::vector<SimpleToken> tokenize() {
            std::vector<SimpleToken> tokens;
            while (pos_ < input_.size()) {
                char c = input_[pos_];
                if (std::isspace(static_cast<unsigned char>(c))) { advance(); continue; }
                if (auto tok = tryMatchID()) {
                    tokens.push_back(*tok); continue;
                }
                if (auto tok = tryMatchHELLO()) {
                    tokens.push_back(*tok); continue;
                }
                throw std::runtime_error("Unexpected character at line " + std::to_string(line_) + " col " + std::to_string(col_));
            }

            tokens.push_back(SimpleToken{SimpleTokenKind::Eof, "", line_, col_});
            return tokens;
        }

    private:
        std::string input_;
        size_t pos_;
        int line_;
        int col_;

        void advance() {
            if (pos_ < input_.size()) {
                if (input_[pos_] == '\n') { line_++; col_ = 1; }
                else { col_++; }
                pos_++;
            }
        }

        char peek(size_t offset = 0) const {
            return (pos_ + offset < input_.size()) ? input_[pos_ + offset] : '\0';
        }

        std::optional<SimpleToken> tryMatchID() {
            size_t saved_pos = pos_;
            int saved_line = line_;
            int saved_col = col_;
            size_t start = pos_;
            while (pos_ < input_.size() && charInRange(input_[pos_])) { advance(); }
            if (pos_ == start) { return std::nullopt; }
            std::string text = input_.substr(start, pos_ - start);

            return SimpleToken{SimpleTokenKind::ID, text, saved_line, saved_col};
        }

        std::optional<SimpleToken> tryMatchWS() {
            size_t saved_pos = pos_;
            int saved_line = line_;
            int saved_col = col_;
            size_t start = pos_;
            while (pos_ < input_.size() && charInRange(input_[pos_])) { advance(); }
            if (pos_ == start) { return std::nullopt; }
            std::string text = input_.substr(start, pos_ - start);

            return std::nullopt;
        }

        std::optional<SimpleToken> tryMatchHELLO() {
            size_t saved_pos = pos_;
            int saved_line = line_;
            int saved_col = col_;
            const std::string target = "hello";
            for (size_t i = 0; i < target.size(); i++) {
                if (peek(i) != target[i]) { pos_ = saved_pos; return std::nullopt; }
            }
            std::string text = input_.substr(saved_pos, target.size());
            for (size_t i = 0; i < target.size(); i++) { advance(); }
            return SimpleToken{SimpleTokenKind::HELLO, text, saved_line, saved_col};
        }

    };

    struct SimpleNode {
        std::string kind;
        std::vector<std::shared_ptr<SimpleNode>> children;
        std::optional<std::string> text;
        std::optional<SimpleTokenKind> token_kind;

        explicit SimpleNode(const std::string& k) : kind(k) {}

        void add_child(std::shared_ptr<SimpleNode> child) {
            children.push_back(std::move(child));
        }

        std::string to_string(int indent = 0) const {
            std::ostringstream ss;
            ss << std::string(indent, ' ') << kind;
            if (text) ss << ": '" << *text << "'";
            ss << '\n';
            for (auto& child : children) ss << child->to_string(indent + 2);
            return ss.str();
        }
    };

    class SimpleParser {
        public:
            explicit SimpleParser(const std::vector<SimpleToken>& tokens) : tokens_(tokens), pos_(0) {}

            std::shared_ptr<SimpleNode> parse() {
                return parseStart();
            }

        private:
            std::vector<SimpleToken> tokens_;
            size_t pos_;

            const SimpleToken& current() const {
                return pos_ < tokens_.size() ? tokens_[pos_] : tokens_.back();
            }

            const SimpleToken* match(SimpleTokenKind kind) {
                if (current().kind == kind) { return &tokens_[pos_++]; }
                return nullptr;
            }

            const SimpleToken& expect(SimpleTokenKind kind) {
                if (auto* tok = match(kind)) { return *tok; }
                auto& cur = current();
                throw std::runtime_error("Unexpected token at line " + std::to_string(cur.line));
            }

            std::shared_ptr<SimpleNode> parseStart() {
                auto node = std::make_shared<SimpleNode>("start");
                { auto& t = expect(SimpleTokenKind::HELLO);
                  auto tn = std::make_shared<SimpleNode>("Token"); tn->text = t.text; node->add_child(tn); }
                { auto& t = expect(SimpleTokenKind::ID);
                  auto tn = std::make_shared<SimpleNode>("Token"); tn->text = t.text; node->add_child(tn); }
                return node;
            }

        };

        inline bool charInRange(char c) { return false; /* implement based on grammar */ }

        #endif /* SIMPLE_PARSER_HPP */
