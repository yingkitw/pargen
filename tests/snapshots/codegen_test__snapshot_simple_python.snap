"""Generated by pargen - do not edit manually"""
from __future__ import annotations
from dataclasses import dataclass, field
from enum import Enum, auto
from typing import List, Optional

class SimpleTokenKind(Enum):
    Eof = auto()
    ID = auto()
    WS = auto()
    HELLO = auto()

@dataclass
class SimpleToken:
    kind: SimpleTokenKind
    text: str = ""
    line: int = 0
    col: int = 0

class SimpleLexer:
    def __init__(self, input: str):
        self.input = input
        self.pos = 0
        self.line = 1
        self.col = 1

    def tokenize(self) -> List[SimpleToken]:
        tokens: List[SimpleToken] = []
        while self.pos < len(self.input):
            c = self.input[self.pos]
            if c in ' \t\n\r':
                self._advance()
                continue
            tok = self._try_match_i_d()
            if tok is not None:
                tokens.append(tok)
                continue
            tok = self._try_match_h_e_l_l_o()
            if tok is not None:
                tokens.append(tok)
                continue
            raise ValueError(f'Unexpected character {self.input[self.pos]!r} at line {self.line} col {self.col}')

        tokens.append(SimpleToken(kind=SimpleTokenKind.Eof, line=self.line, col=self.col))
        return tokens

    def _advance(self) -> None:
        if self.pos < len(self.input):
            if self.input[self.pos] == '\n':
                self.line += 1
                self.col = 1
            else:
                self.col += 1
            self.pos += 1

    def _peek(self, offset: int = 0) -> str | None:
        pos = self.pos + offset
        if pos < len(self.input): return self.input[pos]
        return None

    def _try_match_i_d(self) -> Optional[SimpleToken]:
        saved_pos = self.pos
        saved_line = self.line
        saved_col = self.col
        start = self.pos
        while self.pos < len(self.input) and self._char_in_range(self.input[self.pos]):
            self._advance()
        if self.pos == start: return None
        text = self.input[start:self.pos]

        return SimpleToken(kind=SimpleTokenKind.ID, text=text, line=saved_line, col=saved_col)

    def _try_match_w_s(self) -> Optional[SimpleToken]:
        saved_pos = self.pos
        saved_line = self.line
        saved_col = self.col
        start = self.pos
        while self.pos < len(self.input) and self._char_in_range(self.input[self.pos]):
            self._advance()
        if self.pos == start: return None
        text = self.input[start:self.pos]

        return None  # skip

    def _try_match_h_e_l_l_o(self) -> Optional[SimpleToken]:
        saved_pos = self.pos
        saved_line = self.line
        saved_col = self.col
        target = "hello"
        for i, c in enumerate(target):
            if self._peek(i) != c:
                self.pos = saved_pos
                return None
        text = self.input[saved_pos:saved_pos + len(target)]
        for _ in target: self._advance()
        return SimpleToken(kind=SimpleTokenKind.HELLO, text=text, line=saved_line, col=saved_col)


@dataclass
class SimpleNode:
    kind: str = ""
    children: List[SimpleNode] = field(default_factory=list)
    text: Optional[str] = None
    token_kind: Optional[SimpleTokenKind] = None

class SimpleParser:
    def __init__(self, tokens: List[SimpleToken]):
        self.tokens = tokens
        self.pos = 0

    def parse(self) -> SimpleNode:
        return self._parse_start()

    def _current(self) -> SimpleToken:
        if self.pos < len(self.tokens): return self.tokens[self.pos]
        return self.tokens[-1]

    def _match(self, kind: SimpleTokenKind) -> Optional[SimpleToken]:
        if self._current().kind == kind:
            tok = self.tokens[self.pos]
            self.pos += 1
            return tok
        return None

    def _expect(self, kind: SimpleTokenKind) -> SimpleToken:
        tok = self._match(kind)
        if tok is not None: return tok
        cur = self._current()
        raise ValueError(f'Unexpected token {cur.kind} ("{cur.text}") at line {cur.line} col {cur.col}')

    def _parse_start(self) -> SimpleNode:
        node = SimpleNode(kind="start")
        tok = self._expect(SimpleTokenKind.HELLO)
        node.children.append(SimpleNode(kind='Token', text=tok.text, token_kind=tok.kind))
        tok = self._expect(SimpleTokenKind.ID)
        node.children.append(SimpleNode(kind='Token', text=tok.text, token_kind=tok.kind))
        return node
