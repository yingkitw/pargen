// Generated by pargen - do not edit manually

export enum SimpleTokenKind {
  ID,
  WS,
  HELLO,
  Eof = 'EOF',
}

export interface SimpleToken {
  kind: SimpleTokenKind;
  text: string;
  line: number;
  col: number;
}

export class SimpleLexer {
  private input: string;
  private pos: number;
  private line: number;
  private col: number;

  constructor(input: string) {
    this.input = input;
    this.pos = 0;
    this.line = 1;
    this.col = 1;
  }

  tokenize(): SimpleToken[] {
    const tokens: SimpleToken[] = [];
    while (this.pos < this.input.length) {
      const c = this.input[this.pos];
      if (c === ' ' || c === '\t' || c === '\n' || c === '\r') {
        this.advance(); continue;
      }
      const iD = this.tryMatchID();
      if (iD) {
        tokens.push(iD); continue;
      }
      const hELLO = this.tryMatchHELLO();
      if (hELLO) {
        tokens.push(hELLO); continue;
      }
      throw new Error(`Unexpected character '${this.input[this.pos]}' at line ${this.line} col ${this.col}`);
    }

    tokens.push({ kind: SimpleTokenKind.Eof, text: '', line: this.line, col: this.col });
    return tokens;
  }

  private advance(): void {
    if (this.pos < this.input.length) {
      if (this.input[this.pos] === '\n') { this.line++; this.col = 1; }
      else { this.col++; }
      this.pos++;
    }
  }

  private peek(offset: number = 0): string | undefined {
    return this.input[this.pos + offset];
  }

  private tryMatchID(): SimpleToken | null {
    const savedPos = this.pos;
    const savedLine = this.line;
    const savedCol = this.col;
    const start = this.pos;
    while (this.pos < this.input.length && this.charInRange(this.input[this.pos])) {
      this.advance();
    }
    if (this.pos === start) { return null; }
    const text = this.input.substring(start, this.pos);

    return { kind: SimpleTokenKind.ID, text, line: savedLine, col: savedCol };
  }

  private tryMatchWS(): SimpleToken | null {
    const savedPos = this.pos;
    const savedLine = this.line;
    const savedCol = this.col;
    const start = this.pos;
    while (this.pos < this.input.length && this.charInRange(this.input[this.pos])) {
      this.advance();
    }
    if (this.pos === start) { return null; }
    const text = this.input.substring(start, this.pos);

    return null as any; // skip
  }

  private tryMatchHELLO(): SimpleToken | null {
    const savedPos = this.pos;
    const savedLine = this.line;
    const savedCol = this.col;
    const target = "hello";
    for (let i = 0; i < target.length; i++) {
      if (this.peek(i) !== target[i]) { return null; }
    }
    const text = this.input.substring(savedPos, savedPos + target.length);
    for (let i = 0; i < target.length; i++) { this.advance(); }
    return { kind: SimpleTokenKind.HELLO, text, line: savedLine, col: savedCol };
  }

}

export interface SimpleNode {
  kind: string;
  children: SimpleNode[];
  text?: string;
  tokenKind?: SimpleTokenKind;
}

export function createSimpleNode(kind: string): SimpleNode {
  return { kind, children: [] };
}

export function createTokenNode(text: string, kind: SimpleTokenKind): SimpleNode {
  return { kind: 'Token', children: [], text, tokenKind: kind };
}

export class SimpleParser {
  private tokens: SimpleToken[];
  private pos: number;

  constructor(tokens: SimpleToken[]) {
    this.tokens = tokens;
    this.pos = 0;
  }

  parse(): SimpleNode {
    return this.parseStart();
  }

  private current(): SimpleToken {
    return this.tokens[this.pos] || this.tokens[this.tokens.length - 1];
  }

  private matchToken(kind: SimpleTokenKind): SimpleToken | null {
    if (this.current().kind === kind) {
      return this.tokens[this.pos++];
    }
    return null;
  }

  private expect(kind: SimpleTokenKind): SimpleToken {
    const tok = this.matchToken(kind);
    if (!tok) {
      const cur = this.current();
      throw new Error(`Unexpected token ${cur.kind} ('${cur.text}') at line ${cur.line} col ${cur.col}`);
    }
    return tok;
  }

  private parseStart(): SimpleNode {
    const node = createSimpleNode("start");
    node.children.push(createTokenNode(this.expect(SimpleTokenKind.HELLO).text, SimpleTokenKind.HELLO));
    node.children.push(createTokenNode(this.expect(SimpleTokenKind.ID).text, SimpleTokenKind.ID));
    return node;
  }

}
